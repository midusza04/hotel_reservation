{
  "title": "Ray Hotel - Overview",
  "uid": "ray-hotel-overview",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Reservations (confirmed)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "increase(hotel_reservations_total{status=\"confirmed\"}[1h])",
          "legendFormat": "confirmed"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Reservations (failed)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "increase(hotel_reservations_total{status=\"failed\"}[1h])",
          "legendFormat": "failed"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Payments (failed)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "increase(hotel_payments_total{status=\"failed\"}[1h])",
          "legendFormat": "failed"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Holds",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "hotel_active_holds", "legendFormat": "holds" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(hotel_http_requests_total[1m]))",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP Error Rate (5xx + 504)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (status_code) (rate(hotel_http_requests_total{status_code=~\"5..\"}[1m]))",
          "legendFormat": "{{status_code}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Booking Duration (p50 / p95)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(hotel_booking_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(hotel_booking_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Cancellation Duration (p50 / p95)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(hotel_cancellation_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(hotel_cancellation_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ]
    }
  ]
}
